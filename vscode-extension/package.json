{
  "name": "brainiac-vscode-mcp",
  "displayName": "BrAIniac MCP",
  "description": "Registers the local BrAIniac backend as a VS Code MCP server.",
  "version": "0.1.2",
  "publisher": "brainiac",
  "engines": {
    "vscode": "^1.102.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "onStartupFinished",
    "onCommand:brainiacMcp.signIn",
    "onCommand:brainiacMcp.signOut",
    "onCommand:brainiacMcp.reconnect",
    "onCommand:brainiacMcp.useDevToken"
  ],
  "main": "./dist/extension.js",
  "contributes": {
    "mcpServerDefinitionProviders": [
      {
        "id": "brainiacMcp",
        "label": "BrAIniac MCP"
      }
    ],
    "commands": [
      {
        "command": "brainiacMcp.signIn",
        "title": "BrAIniac: Sign in"
      },
      {
        "command": "brainiacMcp.signOut",
        "title": "BrAIniac: Sign out"
      },
      {
        "command": "brainiacMcp.reconnect",
        "title": "BrAIniac: Reconnect MCP"
      },
      {
        "command": "brainiacMcp.useDevToken",
        "title": "BrAIniac: Use Dev Token"
      }
    ],
    "configuration": {
      "title": "BrAIniac MCP",
      "properties": {
        "brainiacMcp.backendUrl": {
          "type": "string",
          "default": "http://localhost:8080/mcp",
          "description": "BrAIniac backend MCP endpoint URL."
        }
      }
    }
  },
  "scripts": {
    "build": "tsc -p .",
    "compile": "npm run build && node ./scripts/smoke-test.mjs",
    "test": "node ./scripts/smoke-test.mjs"
  },
  "devDependencies": {
    "@types/vscode": "^1.102.0",
    "typescript": "^5.9.3"
  }
}
