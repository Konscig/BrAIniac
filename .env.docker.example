POSTGRES_USER=postgres
POSTGRES_PASSWORD=change-me
POSTGRES_DB=brainiac
DATABASE_URL=postgresql://postgres:change-me@db:5432/brainiac?schema=public

JWT_SECRET_KEY=change-me-generate-64-bytes
OPENROUTER_API_KEY=
JUDGE_MISTRAL_API_KEY=

REDIS_URL=redis://redis:6379
REDIS_KEY_PREFIX=brainiac:prod
REDIS_REQUIRED=true
REDIS_CONNECT_TIMEOUT_MS=5000
RUNTIME_CACHE_ENABLED=true
RUNTIME_PROGRESS_ENABLED=true

AUTH_RATE_LIMIT_MAX=20
AUTH_RATE_LIMIT_WINDOW_MS=60000
JUDGE_RATE_LIMIT_MAX=10
PIPELINE_EXECUTE_RATE_LIMIT_MAX=20
MCP_RATE_LIMIT_MAX=120
OPENROUTER_RATE_LIMIT_MAX=60
PROVIDER_COOLDOWN_MS=30000
