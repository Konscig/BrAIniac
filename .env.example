PG_USER=
PG_PASSWORD=
PG_DB=
PG_PORT=
PG_HOST=

JWT_SECRET_KEY=
DATABASE_URL=
ENVIRON=dev
CORS_ORIGINS=http://localhost:3000

# OpenRouter (runtime LLM used by AgentCall etc.)
OPENROUTER_API_KEY=
OPENROUTER_LLM_MODEL=

# Judge feature (001-ai-judge)
JUDGE_PROVIDER=mistral
JUDGE_MISTRAL_API_KEY=
JUDGE_MISTRAL_MODEL=ministral-3b-2410
JUDGE_OPENROUTER_MODEL=
JUDGE_EVAL_WORKER_URL=http://judge-eval-worker:8001
JUDGE_EVAL_WORKER_TIMEOUT_MS=30000
JUDGE_MAX_ATTEMPTS_PER_ITEM=3
JUDGE_SOFT_RETRY_DELAY_MS=800
EVAL_INFLIGHT_STALE_MS=600000
JUDGE_FAIL_RATE_MAX=0.5
JUDGE_MAX_ITEMS_PER_ASSESSMENT=500

# Express body-parser limit. Дефолт 12mb режется при upsert'е сотен эмбеддингов
# с большой размерностью (256 × 2048 dims). Для real RAG поднимать до 64mb.
HTTP_JSON_LIMIT=64mb

# OpenRouter request timeout. Дефолт 20s режется на запросе эмбеддингов
# 256 чанков одним батчем; для real RAG разумно держать 60s.
OPENROUTER_TIMEOUT_MS=60000

# MCP adapter is disabled by default until explicitly enabled.
MCP_ENABLED=false
MCP_PATH=/mcp

# Browser web refresh cookies are Secure by default. Set false only for plain
# http://localhost local development; hosted/HTTPS environments must keep true.
WEB_REFRESH_COOKIE_SECURE=true
WEB_REFRESH_COOKIE_SAMESITE=lax
